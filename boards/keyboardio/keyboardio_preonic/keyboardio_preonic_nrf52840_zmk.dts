/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/led/led.h>

// 키 스위치 위치와 크기를 정의하기 위한 매크로
#include <physical_layouts.dtsi>

/ {
	model = "Keyboardio Preonic";
	compatible = "keyboardio_preonic";

	chosen {
		zephyr,code-partition = &slot0_partition;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zmk,kscan = &kscan0;
		zmk,matrix_transform = &mit_layout;
		zmk,underglow = &led_strip;
		zmk,physical-layout = &physical_layout0; // ZMK Studio용 물리적 레이아웃 등록
	};

	#define KRC(row, col) (((row) * 12) + (col))

	mit_layout: mit_layout {
		compatible = "zmk,matrix-transform";
		columns = <12>;
		rows = <6>;
		map = <
			KRC(5,9) KRC(5,10) KRC(5,11)
			KRC(0,0) KRC(0,1) KRC(0,2) KRC(0,3) KRC(0,4) KRC(0,5) KRC(0,6) KRC(0,7) KRC(0,8) KRC(0,9) KRC(0,10) KRC(0,11)
			KRC(1,0) KRC(1,1) KRC(1,2) KRC(1,3) KRC(1,4) KRC(1,5) KRC(1,6) KRC(1,7) KRC(1,8) KRC(1,9) KRC(1,10) KRC(1,11)
			KRC(2,0) KRC(2,1) KRC(2,2) KRC(2,3) KRC(2,4) KRC(2,5) KRC(2,6) KRC(2,7) KRC(2,8) KRC(2,9) KRC(2,10) KRC(2,11)
			KRC(3,0) KRC(3,1) KRC(3,2) KRC(3,3) KRC(3,4) KRC(3,5) KRC(3,6) KRC(3,7) KRC(3,8) KRC(3,9) KRC(3,10) KRC(3,11)
			KRC(4,0) KRC(4,1) KRC(4,2) KRC(4,3) KRC(4,4)     KRC(4,5)     KRC(4,7) KRC(4,8) KRC(4,9) KRC(4,10) KRC(4,11)
		>;
	};

	// ZMK Studio를 위한 키보드 물리적 모양 정의 (상단 3키 + 5x12 격자)
	physical_layout0: physical_layout_0 {
		compatible = "zmk,physical-layout";
		display-name = "Default Layout";
		transform = <&mit_layout>;
		keys  // <가로길이 세로길이 X좌표 Y좌표>
			// 0번째 줄 (상단 추가 3키: y=0) - 오른쪽으로 치우친 배치 가정
			= <&key_physical_attrs 100 100 900 0>
			, <&key_physical_attrs 100 100 1000 0>
			, <&key_physical_attrs 100 100 1100 0>

			// 1번째 줄 (y=100)
			, <&key_physical_attrs 100 100 0 100>   , <&key_physical_attrs 100 100 100 100> , <&key_physical_attrs 100 100 200 100>
			, <&key_physical_attrs 100 100 300 100> , <&key_physical_attrs 100 100 400 100> , <&key_physical_attrs 100 100 500 100>
			, <&key_physical_attrs 100 100 600 100> , <&key_physical_attrs 100 100 700 100> , <&key_physical_attrs 100 100 800 100>
			, <&key_physical_attrs 100 100 900 100> , <&key_physical_attrs 100 100 1000 100>, <&key_physical_attrs 100 100 1100 100>

			// 2번째 줄 (y=200)
			, <&key_physical_attrs 100 100 0 200>   , <&key_physical_attrs 100 100 100 200> , <&key_physical_attrs 100 100 200 200>
			, <&key_physical_attrs 100 100 300 200> , <&key_physical_attrs 100 100 400 200> , <&key_physical_attrs 100 100 500 200>
			, <&key_physical_attrs 100 100 600 200> , <&key_physical_attrs 100 100 700 200> , <&key_physical_attrs 100 100 800 200>
			, <&key_physical_attrs 100 100 900 200> , <&key_physical_attrs 100 100 1000 200>, <&key_physical_attrs 100 100 1100 200>

			// 3번째 줄 (y=300)
			, <&key_physical_attrs 100 100 0 300>   , <&key_physical_attrs 100 100 100 300> , <&key_physical_attrs 100 100 200 300>
			, <&key_physical_attrs 100 100 300 300> , <&key_physical_attrs 100 100 400 300> , <&key_physical_attrs 100 100 500 300>
			, <&key_physical_attrs 100 100 600 300> , <&key_physical_attrs 100 100 700 300> , <&key_physical_attrs 100 100 800 300>
			, <&key_physical_attrs 100 100 900 300> , <&key_physical_attrs 100 100 1000 300>, <&key_physical_attrs 100 100 1100 300>

			// 4번째 줄 (y=400)
			, <&key_physical_attrs 100 100 0 400>   , <&key_physical_attrs 100 100 100 400> , <&key_physical_attrs 100 100 200 400>
			, <&key_physical_attrs 100 100 300 400> , <&key_physical_attrs 100 100 400 400> , <&key_physical_attrs 100 100 500 400>
			, <&key_physical_attrs 100 100 600 400> , <&key_physical_attrs 100 100 700 400> , <&key_physical_attrs 100 100 800 400>
			, <&key_physical_attrs 100 100 900 400> , <&key_physical_attrs 100 100 1000 400>, <&key_physical_attrs 100 100 1100 400>

			// 5번째 줄 (y=500, 중앙에 200 폭의 2U 스페이스바)
			, <&key_physical_attrs 100 100 0 500>   , <&key_physical_attrs 100 100 100 500> , <&key_physical_attrs 100 100 200 500>
			, <&key_physical_attrs 100 100 300 500> , <&key_physical_attrs 100 100 400 500> 
			, <&key_physical_attrs 200 100 500 500> // 2U Spacebar
			, <&key_physical_attrs 100 100 700 500> , <&key_physical_attrs 100 100 800 500>
			, <&key_physical_attrs 100 100 900 500> , <&key_physical_attrs 100 100 1000 500>, <&key_physical_attrs 100 100 1100 500>
			;
	};

	kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
		label = "KSCAN";
		diode-direction = "col2row";
		row-gpios
			= <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			, <&gpio0 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			, <&gpio1 8  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			, <&gpio0 27 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			, <&gpio0 8  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			, <&gpio0 6  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			;
		col-gpios
			= <&gpio1 14 GPIO_ACTIVE_HIGH>
			, <&gpio1 12 GPIO_ACTIVE_HIGH>
			, <&gpio0 25 GPIO_ACTIVE_HIGH>
			, <&gpio0 26 GPIO_ACTIVE_HIGH>
			, <&gpio0 21 GPIO_ACTIVE_HIGH>
			, <&gpio0 23 GPIO_ACTIVE_HIGH>
			, <&gpio0 12 GPIO_ACTIVE_HIGH>
			, <&gpio1 9  GPIO_ACTIVE_HIGH>
			, <&gpio0 4  GPIO_ACTIVE_HIGH>
			, <&gpio0 31 GPIO_ACTIVE_HIGH>
			, <&gpio0 30 GPIO_ACTIVE_HIGH>
			, <&gpio0 29 GPIO_ACTIVE_HIGH>
			;
	};

	encoder: encoder {
		compatible = "alps,ec11";
		a-gpios = <&gpio0 28 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
		b-gpios = <&gpio0 2  (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
		steps = <80>;
		status = "okay";
	};

	sensors: sensors {
		compatible = "zmk,keymap-sensors";
		sensors = <&encoder>;
		triggers-per-rotation = <20>;
	};
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
	butterfly_power: ext_power_gpio {
		compatible = "zmk,ext-power-generic";
		status = "okay";
		control-gpios = <&gpio1 5 GPIO_ACTIVE_HIGH>;
	};
};

&spi3 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi3_default>;
	pinctrl-names = "default";

	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";
		label = "SK6812";
		reg = <0>;
		spi-max-frequency = <4000000>;
		chain-length = <9>;
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
		color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;
	};
};

&pinctrl {
	spi3_default: spi3_default {
		group1 {
			psels = <NRF_PSEL(SPIM_MOSI, 0, 24)>;
		};
	};
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;
		boot_partition: partition@0 { label = "mcuboot"; reg = <0x00000000 0x0000C000>; };
		slot0_partition: partition@c000 { label = "image-0"; reg = <0x0000C000 0x00076000>; };
		slot1_partition: partition@82000 { label = "image-1"; reg = <0x00082000 0x00076000>; };
		scratch_partition: partition@f8000 { label = "image-scratch"; reg = <0x000F8000 0x00006000>; };
		storage_partition: partition@fe000 { label = "storage"; reg = <0x000FE000 0x00002000>; };
	};
};

&gpiote {
	status = "okay";
};

// USB 디바이스 컨트롤러 활성화 (링킹 에러 해결)
&usbd {
	status = "okay";
	cdc_acm_uart: cdc_acm_uart {
		compatible = "zephyr,cdc-acm-uart";
		label = "CDC_ACM_0";
	};
};
