CONFIG_BOARD_KEYBOARDIO_PREONIC=y

# Enable MPU (메모리 보호 및 안정성)
CONFIG_ARM_MPU=y

# enable GPIO
CONFIG_GPIO=y

# 부팅 멈춤 방지를 위한 설정
CONFIG_LOG=n
CONFIG_SERIAL=n
CONFIG_UART_INTERRUPT_DRIVEN=n

# 칩셋 초기화 안정화
CONFIG_CLOCK_CONTROL_NRF_K32SRC_RC=y
CONFIG_CLOCK_CONTROL_NRF_K32SRC_RC_CALIBRATION=y

# USB 인식 오류 방지 (기본 HID만 활성화)
CONFIG_USB_DEVICE_STACK=y
CONFIG_ZMK_USB=y
CONFIG_USB_DEVICE_VID=0x3496
CONFIG_USB_DEVICE_PID=0x0005
CONFIG_USB_DEVICE_MANUFACTURER="Keyboardio"
CONFIG_USB_DEVICE_PRODUCT="Preonic"

# Bluetooth 활성화
CONFIG_ZMK_BLE=y

# Rotary encoder events (노브 동작 핵심)
CONFIG_EC11=y
CONFIG_EC11_TRIGGER_GLOBAL_THREAD=y

# 안정성을 위해 임시로 절전 기능 비활성화
CONFIG_ZMK_SLEEP=n

# Butterfly LEDs use ZMK's "underglow" feature
CONFIG_ZMK_RGB_UNDERGLOW=y

# 메모리 파티션 및 설정 저장소 (부팅 및 페어링 유지 핵심)
CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_MPU_ALLOW_FLASH_WRITE=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y

# UF2 펌웨어 포맷 출력 활성화
CONFIG_BUILD_OUTPUT_UF2=y
